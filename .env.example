# Django Configuration
DJANGO_DEBUG=True
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# PostgreSQL Database
DATABASE_ENGINE=django.db.backends.postgresql
DATABASE_NAME=saed_database
DATABASE_USER=postgres
DATABASE_PASSWORD=your-postgres-password
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_CONN_MAX_AGE=60

# SQLite (fallback if DATABASE_ENGINE is empty)
# DATABASE_ENGINE=
# SQLITE_NAME=db.sqlite3

# CORS / CSRF (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002
CSRF_TRUSTED_ORIGINS=http://localhost:3002,http://127.0.0.1:3002

# Email (SMTP - Gmail)
# Enable 2FA on your Google account, then generate an App Password:
# https://myaccount.google.com/apppasswords
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# MD email for trainer registration notifications
MD_EMAIL=md@nysc.gov.ng

# Frontend URL (for email verification links)
FRONTEND_URL=http://localhost:3002

# Paystack Payment Gateway
PAYSTACK_SECRET_KEY=sk_test_your_secret_key_here
PAYSTACK_PUBLIC_KEY=pk_test_your_public_key_here
PAYSTACK_API_URL=https://api.paystack.co
PAYSTACK_DEFAULT_AMOUNT=50000
